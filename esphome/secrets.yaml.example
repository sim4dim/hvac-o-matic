# ESPHome Secrets Template
# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored and will not be committed.

hvac_wifi_ssid: "your_wifi_ssid"
hvac_wifi_password: "your_wifi_password"
hvac_api_key: "generate_with: openssl rand -base64 32"
hvac_ota_password: "your_ota_password"
mqtt_broker: "your_mqtt_broker_ip"
